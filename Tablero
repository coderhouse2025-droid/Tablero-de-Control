def listar_archivos_drive(folder_id,
        tipos=('application/pdf', 'image/jpeg', 'image/png')):
    """Lista archivos en una carpeta de Drive por tipo MIME."""
    mime_q = ' or '.join([f"mimeType='{t}'" for t in tipos])
    query  = f"'{folder_id}' in parents and ({mime_q}) and trashed=false"
    res    = drive_service.files().list(
        q=query,
        fields='files(id, name, mimeType, createdTime)',
        pageSize=100
    ).execute()
    return res.get('files', [])

