from IPython.display import display, HTML

def generar_insights(df, df_mensual, df_cat):
    insights = []
    mes_max = df_mensual.loc[df_mensual['gasto'].idxmax()]
    insights.append(('📅 Mes de mayor gasto',
        f"<b>{mes_max['mes']}</b> — {MONEDA}{mes_max['gasto']:,.0f}"))
    cat_top = df_cat.iloc[0]
    pct     = cat_top['monto'] / df_cat['monto'].sum() * 100
    insights.append(('🏆 Categoría principal',
        f"<b>{cat_top['categoria'].upper()}</b> — {pct:.1f}%"))
    tasa   = df_mensual['tasa_ahorro'].mean()
    estado = '✅ Saludable' if tasa >= 20 else '⚠️ Mejorable' if tasa >= 0 else '🚨 Déficit'
    insights.append(('💰 Tasa de ahorro',
        f"{estado} — promedio <b>{tasa:.1f}%</b>"))
    if len(df_mensual) >= 3:
        tend = df_mensual['gasto'].pct_change().mean() * 100
        icono = '📉' if tend <= 0 else '📈'
        insights.append((f'{icono} Tendencia',
            f"Gastos {'↓' if tend <= 0 else '↑'} <b>{abs(tend):.1f}%</b> por mes"))
    mes_ef = df_mensual.loc[df_mensual['tasa_ahorro'].idxmax()]
    insights.append(('🌟 Mes más eficiente',
        f"<b>{mes_ef['mes']}</b> — {mes_ef['tasa_ahorro']}%"))
    prov   = df.groupby('proveedor')['monto'].sum()
    insights.append(('🏢 Proveedor principal',
        f"<b>{prov.idxmax()}</b> — {MONEDA}{prov.max():,.0f}"))
    deficit = df_mensual[df_mensual['ahorro'] < 0]['mes'].tolist()
    if deficit:
        insights.append(('🚨 Meses en déficit', ' '.join(deficit)))
    else:
        insights.append(('✅ Sin déficit', 'Ingresos superaron gastos todos los meses.'))
    return insights

insights = generar_insights(df, df_mensual, df_cat)

